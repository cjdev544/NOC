{
  "name": "noc",
  "version": "1.0.0",
  "description": "",
  "main": "app.js",
  "scripts": {
    "dev": "tsx watch src/app.ts",
    "build": "rimraf ./dist && tsc",
    "start": "npm run build && node dist/app.js",
    "docker:test": "docker compose -f docker-compose.test.yml --env-file .env.test up -d",
    "typecheck": "tsc --noEmit",
    "test": "npm run typecheck && npm run docker:test && vitest",
    "test:watch": "npm run typecheck && npm run docker:test && vitest --watch",
    "test:coverage": "npm run typecheck && npm run docker:test && vitest run --coverage"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "devDependencies": {
    "@types/node": "25.3.0",
    "@types/nodemailer": "7.0.11",
    "@types/pg": "8.18.0",
    "@vitest/coverage-v8": "4.0.18",
    "prisma": "7.4.2",
    "rimraf": "6.1.3",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "vitest": "4.0.18"
  },
  "dependencies": {
    "@prisma/adapter-pg": "7.4.2",
    "@prisma/client": "7.4.2",
    "cron": "4.4.0",
    "dotenv": "17.3.1",
    "env-var": "7.5.0",
    "mongoose": "9.2.4",
    "nodemailer": "8.0.1",
    "pg": "8.20.0"
  }
}
